{
  "version": 2,
  "builds": [
    {
      "src": "frontend-ui/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "backend/**"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend-ui/assets/$1"
    },
    {
      "src": "/([^/]+\\.[^/]+)",
      "dest": "/frontend-ui/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend-ui/index.html"
    }
  ]
}
